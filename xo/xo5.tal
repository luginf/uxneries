( premiere case vide )
@ai-any-empty ( -- )
	#00
	&loop
		DUP #18 GTH ,&done JCN
		DUP #00 SWP ;board ADD2 LDA #00 EQU ,&found JCN
		INC ,&loop JMP
	&found
		DUP #05 DIV INC ;ai-move-h STA
		DUP #05 DIV #05 MUL SUB INC ;ai-move-w STA
		JMP2r
	&done POP
JMP2r

( strategie IA : 1-gagner 2-bloquer 3-centre 4-coin 5-case vide )
@ai-move ( -- )
	;game/cursor-pos-h LDA ;ai-save-h STA
	;game/cursor-pos-w LDA ;ai-save-w STA
	#00 ;ai-found STA
	LIT "o ;ai-scan-for JSR2
	;ai-found LDA ;&do-place JCN2
	LIT "x ;ai-scan-for JSR2
	;ai-found LDA ;&do-place JCN2
	;board/cell33 LDA #00 NEQ ,&nc JCN
	#03 ;ai-move-h STA #03 ;ai-move-w STA ;&do-place JMP2
	&nc
	;board/cell11 LDA #00 NEQ ,&nc11 JCN
	#01 ;ai-move-h STA #01 ;ai-move-w STA ;&do-place JMP2
	&nc11
	;board/cell51 LDA #00 NEQ ,&nc51 JCN
	#01 ;ai-move-h STA #05 ;ai-move-w STA ;&do-place JMP2
	&nc51
	;board/cell15 LDA #00 NEQ ,&nc15 JCN
	#05 ;ai-move-h STA #01 ;ai-move-w STA ;&do-place JMP2
	&nc15
	;board/cell55 LDA #00 NEQ ,&nc55 JCN
	#05 ;ai-move-h STA #05 ;ai-move-w STA ;&do-place JMP2
	&nc55
	;ai-any-empty JSR2
	&do-place
	;ai-move-h LDA ;game/cursor-pos-h STA
	;ai-move-w LDA ;game/cursor-pos-w STA
	LIT "o ;game/cur-player STA
	;place-figure JSR2
	;ai-save-h LDA ;game/cursor-pos-h STA
	;ai-save-w LDA ;game/cursor-pos-w STA
JMP2r

( === VARIABLES === )
@game [
	&x-score 00 &o-score 00
	&cur-player "x
	&cursor-pos-w 03 &cursor-pos-h 03
]
@board [
	&cell11 00 &cell21 00 &cell31 00 &cell41 00 &cell51 00
	&cell12 00 &cell22 00 &cell32 00 &cell42 00 &cell52 00
	&cell13 00 &cell23 00 &cell33 00 &cell43 00 &cell53 00
	&cell14 00 &cell24 00 &cell34 00 &cell44 00 &cell54 00
	&cell15 00 &cell25 00 &cell35 00 &cell45 00 &cell55 00
]
