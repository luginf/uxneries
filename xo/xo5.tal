@ai-i1 00 @ai-i2 00 @ai-i3 00 @ai-ie 00 @ai-he 00 @ai-we 00
@ai-move-h 00 @ai-move-w 00
@ai-found 00
@ai-save-h 00 @ai-save-w 00
@mouse-last-state 00
@mouse-cell-w 00 @mouse-cell-h 00
@mouse-over-board 00
@ptr-px 00 @ptr-py 00

